{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role management",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "displayName"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Potential client lead from the mockup request form.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who requested the mockup" },
        "name": { "type": "string", "description": "Full name of the lead" },
        "email": { "type": "string", "format": "email", "description": "Contact email" },
        "business": { "type": "string", "description": "Name or type of the business" },
        "message": { "type": "string", "description": "Additional notes or project details" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lead was submitted" }
      },
      "required": ["userId", "name", "email", "business"]
    },
    "WaitlistEntry": {
      "title": "Waitlist Entry",
      "description": "User joining the waitlist for the AI TRIO MASTERCLASS.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "product": { "type": "string" }
      },
      "required": ["email", "joinedAt", "product"]
    },
    "AppStats": {
      "title": "App Statistics",
      "description": "Global statistics for the application.",
      "type": "object",
      "properties": {
        "enrollmentCount": { "type": "integer", "minimum": 0 }
      },
      "required": ["enrollmentCount"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "leads": {
      "schema": "Lead",
      "description": "Collection of incoming project leads."
    },
    "waitlist": {
      "schema": "WaitlistEntry",
      "description": "Collection of users waitlisted for the masterclass."
    }
  }
}
