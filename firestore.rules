rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.role in ['customer', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['userId', 'name', 'email', 'business', 'createdAt', 'status']) &&
             data.userId == request.auth.uid &&
             data.status == 'pending' &&
             data.name is string && data.name.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.business is string && data.business.size() > 0 &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /leads/{leadId} {
      allow create: if isSignedIn() && isValidLead(request.resource.data);
      allow read: if isAdmin();
      allow update: if isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }
  }
}
