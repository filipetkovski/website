rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Pillar 0: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: Primitives ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role Lookup - Secure via get() on trusted users collection
    function isAdmin() {
      return isSignedIn() && 
        ((request.auth.token.email == 'filip.petkovski.work@gmail.com' && isEmailVerified()) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // --- PHASE 4: Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
             data.keys().size() == 5 && // Strict Keys
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 256 &&
             data.role in ['customer', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidLead(data) {
      // Optional 'message' field is permitted but must be string if present
      return data.keys().hasAll(['userId', 'name', 'email', 'business', 'createdAt', 'status']) &&
             (data.keys().size() == 6 || (data.keys().size() == 7 && data.keys().hasAll(['message']))) &&
             data.userId == request.auth.uid &&
             data.status == 'pending' &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 256 &&
             data.business is string && data.business.size() > 0 && data.business.size() <= 256 &&
             (!data.keys().hasAll(['message']) || (data.message is string && data.message.size() <= 2000)) &&
             data.createdAt == request.time;
    }

    // --- COLLECTIONS ---

    match /users/{userId} {
      // Pillar 3: Path variable hardening
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      // Admins can lookup users too
      allow get: if isAdmin() && isValidId(userId);

      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming());
      
      allow update: if isSignedIn() && isValidId(userId) && (
        // Admin can modify anyone
        isAdmin() ||
        // User can update their own non-RBAC fields (none currently defined as mutable besides identity)
        (request.auth.uid == userId && incoming().role == existing().role && incoming().uid == existing().uid)
      );
    }

    match /leads/{leadId} {
      allow create: if isEmailVerified() && isValidId(leadId) && isValidLead(incoming());
      
      // Pillar 8: Secure List Queries (No blanket reads)
      allow list: if isAdmin();
      allow get: if isAdmin() && isValidId(leadId);
      
      // Pillar 4: Tiered Identity Logic for updates
      allow update: if isAdmin() && isValidId(leadId) && (
        // Action: Update Status
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['pending', 'completed']
      );

      // Users can see their own leads
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(leadId) && existing().userId == request.auth.uid;
    }
  }
}
